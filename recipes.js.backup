  {name:'Almonds, toasted',amount:45,unit:'g'},
  {name:'Mint and dill',amount:1,unit:'handful'},
  {name:'Za\'atar',amount:5,unit:'g'},
  {name:'Olive oil',amount:80,unit:'ml'},
  {name:'Pomegranate molasses',amount:15,unit:'ml'},
  {name:'Soft feta',amount:150,unit:'g'},
  {name:'Greek yoghurt',amount:95,unit:'g'},
  {name:'Lemon juice',amount:15,unit:'ml'},
],
steps:[
  'Boil beetroots in salted vinegar water until soft, about 1 hour. Peel and wedge.',
  'Blend feta with yoghurt, lemon juice and 1 tbsp olive oil until fluffy.',
  'Toss beetroot with cooked lentils, fennel, rocket, almonds, mint and dill.',
  'Whisk remaining olive oil, vinegar, za\'atar and pomegranate molasses into a dressing. Toss through.',
  'Spread whipped feta on a plate, pile salad over and scatter extra za\'atar.',
]},

{id:25,name:'Tuscan Kale Salad with Fennel, Radish & Ricotta Salata',category:'Salads',difficulty:'medium',serves:2,time:'20 min',calories:280,mainIngredient:'Kale',
ingredients:[
  {name:'Tuscan kale, shredded',amount:2,unit:'bunches'},
  {name:'Red wine vinegar',amount:30,unit:'ml'},
  {name:'Lemon juice',amount:22,unit:'ml'},
  {name:'Radishes, thinly sliced',amount:6,unit:'whole'},
  {name:'Fennel bulb, shaved',amount:1,unit:'whole'},
  {name:'Garlic croutons, crushed',amount:1,unit:'handful'},
  {name:'Ricotta salata, shaved',amount:55,unit:'g'},
  {name:'Olive oil',amount:45,unit:'ml'},
],
steps:[
  'Massage kale with olive oil, vinegar, lemon juice and salt until softened, about 2 minutes.',
  'Add shaved radish and fennel and toss through.',
  'Crush croutons roughly and mix into the salad.',
  'Shave ricotta salata over the top and toss gently before serving.',
]},

{id:26,name:'Wild Rice, Pickled Zucchini, Dukkah & Mozzarella Salad',category:'Salads',difficulty:'medium',serves:2,time:'45 min',calories:520,mainIngredient:'Wild Rice',
ingredients:[
  {name:'Cooked wild rice',amount:150,unit:'g'},
  {name:'Mint leaves',amount:1,unit:'handful'},
  {name:'Mozzarella',amount:300,unit:'g'},
  {name:'White wine vinegar',amount:150,unit:'ml'},
  {name:'Honey',amount:30,unit:'ml'},
  {name:'Red chilli, minced',amount:0.5,unit:'whole'},
  {name:'Zucchini, diced',amount:2,unit:'cups'},
  {name:'Hazelnuts, chopped',amount:130,unit:'g'},
  {name:'Sesame seeds',amount:100,unit:'g'},
  {name:'Coriander seeds',amount:15,unit:'g'},
  {name:'Cumin',amount:15,unit:'g'},
  {name:'Lemon zest',amount:1,unit:'lemon'},
  {name:'Olive oil',amount:300,unit:'ml'},
  {name:'Bread, cubed',amount:0.5,unit:'loaf'},
],
steps:[
  'Heat vinegar with honey, chilli, cloves and a cinnamon stick for 5 minutes. Pour over diced zucchini and steep until cool.',
  'Mix dukkah spices (hazelnuts, sesame, coriander seeds, cumin, lemon zest, pepper, salt). Coat bread cubes with oil and 5 tbsp spice mix. Bake at 180°C until crisp, 15–20 minutes.',
  'Drain pickled zucchini and toss with cooked wild rice, bread crumbs and mint.',
  'Tear mozzarella over the top and sprinkle with more dukkah.',
]},

{id:27,name:'Potato & Pea Salad with Horseradish Ranch',category:'Salads',difficulty:'easy',serves:2,time:'30 min',calories:400,mainIngredient:'Potatoes',
ingredients:[
  {name:'Chat potatoes',amount:1000,unit:'g'},
  {name:'Olive oil',amount:30,unit:'ml'},
  {name:'Leek, sliced',amount:0.5,unit:'small'},
  {name:'Frozen peas, thawed',amount:140,unit:'g'},
  {name:'Mint, chopped',amount:1,unit:'handful'},
  {name:'Dill, chopped',amount:1,unit:'handful'},
  {name:'Baby capers, rinsed',amount:50,unit:'g'},
  {name:'Pea sprouts',amount:1,unit:'handful'},
  {name:'Greek yoghurt',amount:130,unit:'g'},
  {name:'Buttermilk',amount:60,unit:'ml'},
  {name:'Garlic clove, crushed',amount:1,unit:'clove'},
  {name:'White wine vinegar',amount:15,unit:'ml'},
  {name:'Lemon juice',amount:30,unit:'ml'},
  {name:'Horseradish',amount:30,unit:'g'},
],
steps:[
  'Whisk all dressing ingredients (yoghurt, buttermilk, garlic, vinegar, lemon juice, horseradish) together. Season and chill.',
  'Boil potatoes in salted water 15 minutes until tender. Cool and halve.',
  'Fry sliced leek in oil with a pinch of salt for 3 minutes until softened.',
  'Toss potatoes, leek, peas, herbs and capers with dressing until well coated.',
  'Top with pea sprouts to serve.',
]},

{id:28,name:'Grilled Asparagus & Butter Bean Salad',category:'Salads',difficulty:'easy',serves:2,time:'15 min',calories:330,mainIngredient:'Asparagus',
ingredients:[
  {name:'Asparagus, trimmed',amount:2,unit:'bunches'},
  {name:'Olive oil',amount:75,unit:'ml'},
  {name:'Butter beans, rinsed',amount:400,unit:'g'},
  {name:'Capers',amount:30,unit:'g'},
  {name:'Spring onions, sliced',amount:2,unit:'whole'},
  {name:'Dill',amount:1,unit:'handful'},
  {name:'Parsley',amount:1,unit:'handful'},
  {name:'Sherry vinegar',amount:30,unit:'ml'},
  {name:'Chilli in oil',amount:15,unit:'ml'},
  {name:'Lemon zest',amount:1,unit:'lemon'},
],
steps:[
  'Toss asparagus with 1 tbsp oil, salt and pepper. Grill 2 minutes until lightly charred.',
  'Combine charred asparagus with butter beans, capers, spring onions, dill and parsley.',
  'Dress with sherry vinegar, remaining olive oil and chilli in oil. Season well.',
  'Finish with lemon zest and serve.',
]},

{id:29,name:'Grilled Asparagus with Lemon & Parmesan',category:'Salads',difficulty:'easy',serves:2,time:'10 min',calories:150,mainIngredient:'Asparagus',
ingredients:[
  {name:'Asparagus, trimmed',amount:1,unit:'bunch'},
  {name:'Olive oil',amount:30,unit:'ml'},
  {name:'Lemon juice',amount:15,unit:'ml'},
  {name:'Parmesan, shaved',amount:30,unit:'g'},
],
steps:[
  'Toss asparagus with olive oil, salt and pepper.',
  'Grill 3–4 minutes until tender and lightly charred.',
  'Squeeze lemon juice over the top and scatter shaved parmesan to serve.',
]},

{id:30,name:'Kale, Chickpea, Fennel & Date Salad',category:'Salads',difficulty:'easy',serves:2,time:'20 min',calories:450,mainIngredient:'Kale',
ingredients:[
  {name:'Kale leaves, chopped',amount:3,unit:'whole'},
  {name:'Cooked chickpeas',amount:180,unit:'g'},
  {name:'Fennel bulb, finely sliced',amount:1,unit:'whole'},
  {name:'Mint leaves',amount:1,unit:'handful'},
  {name:'Parsley leaves',amount:1,unit:'handful'},
  {name:'Oranges, segmented',amount:2,unit:'whole'},
  {name:'Olive oil',amount:100,unit:'ml'},
  {name:'Orange juice',amount:60,unit:'ml'},
  {name:'Dates, quartered',amount:6,unit:'whole'},
  {name:'Walnuts (optional)',amount:30,unit:'g'},
],
steps:[
  'Massage kale with half the olive oil and some of the orange juice until softened.',
  'Add chickpeas, fennel, herbs, dates and orange segments. Toss well.',
  'Drizzle with remaining oil and orange juice. Season.',
  'Scatter walnuts if using and serve.',
]},

{id:31,name:'Chickpea & Date Salad with Citrus Dressing',category:'Salads',difficulty:'easy',serves:2,time:'15 min',calories:420,mainIngredient:'Chickpeas',
ingredients:[
