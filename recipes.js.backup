  'Toss chickpeas, fennel, herbs, dates and orange segments with the dressing.',
  'Scatter walnuts to serve.',
]},

{id:32,name:'Chickpea, Tomato & Herb Salad with Pomegranate Dressing',category:'Salads',difficulty:'easy',serves:2,time:'20 min',calories:480,mainIngredient:'Chickpeas',
ingredients:[
  {name:'Chickpeas, rinsed',amount:400,unit:'g'},
