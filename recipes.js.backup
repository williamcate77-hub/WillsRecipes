  {name:'Red chilli, finely diced',amount:1,unit:'whole'},
  {name:'Garlic clove, finely diced',amount:1,unit:'clove'},
  {name:'Soy sauce',amount:30,unit:'ml'},
  {name:'Coconut vinegar',amount:15,unit:'ml'},
  {name:'Mirin',amount:15,unit:'ml'},
  {name:'Coconut cream',amount:30,unit:'ml'},
  {name:'Rice vinegar',amount:15,unit:'ml'},
  {name:'Coriander stems, chopped',amount:1,unit:'handful'},
  {name:'Blood orange zest',amount:1,unit:'orange'},
],
steps:[
  'Heat coals until very hot. Place oysters shell-side down over coals, cover with a hot pan to trap smoke. Cook until shells open, about 2 minutes.',
  'Combine soy, coconut vinegar, mirin, coconut cream, rice vinegar, garlic and chilli in a small pan. Simmer 10–15 minutes then cool.',
  'Open oysters, reserving juices. Strain juices into the vinaigrette.',
  'Rinse oyster meat briefly in lightly acidulated water, then return to shells.',
  'Spoon vinaigrette over oysters, garnish with coriander stem and blood orange zest.',
]},

