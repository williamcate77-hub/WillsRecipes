{id:35,name:'Gazpacho (Chilled Tomato Soup)',category:'Soups',difficulty:'easy',serves:4,time:'15 min + 2 hr chill',calories:120,mainIngredient:'Tomatoes',
ingredients:[
  {name:'Ripe tomatoes, chopped',amount:1000,unit:'g'},
  {name:'Cucumber, chopped',amount:1,unit:'whole'},
  {name:'Red capsicum, chopped',amount:1,unit:'whole'},
  {name:'Red onion, chopped',amount:1,unit:'small'},
  {name:'Garlic cloves, chopped',amount:2,unit:'cloves'},
  {name:'Olive oil',amount:45,unit:'ml'},
  {name:'Red wine vinegar',amount:30,unit:'ml'},
  {name:'Stale bread, soaked in water',amount:2,unit:'slices'},
],
steps:[
  'Blend tomatoes, cucumber, capsicum, onion, garlic, olive oil, vinegar and soaked bread until very smooth.',
  'Season well with salt and pepper.',
  'Chill for at least 2 hours before serving.',
  'Serve cold with a drizzle of olive oil.',
]},

{id:36,name:'Minestrone Soup',category:'Soups',difficulty:'easy',serves:4,time:'35 min',calories:280,mainIngredient:'Vegetables',
ingredients:[
  {name:'Olive oil',amount:30,unit:'ml'},
  {name:'Onion, chopped',amount:1,unit:'whole'},
  {name:'Carrots, diced',amount:2,unit:'whole'},
  {name:'Celery sticks, diced',amount:2,unit:'stalks'},
  {name:'Garlic cloves, chopped',amount:2,unit:'cloves'},
  {name:'Zucchini, diced',amount:1,unit:'whole'},
  {name:'Tinned chopped tomatoes',amount:400,unit:'g'},
  {name:'Vegetable stock',amount:1000,unit:'ml'},
  {name:'Cannellini beans, drained',amount:400,unit:'g'},
  {name:'Small pasta (ditalini)',amount:100,unit:'g'},
  {name:'Parsley, chopped',amount:1,unit:'handful'},
],
steps:[
  'Heat oil in a large pot. Sauté onion, carrots, celery and garlic until soft, about 8 minutes.',
  'Add zucchini, tomatoes and stock. Simmer 15 minutes.',
  'Stir in cannellini beans and pasta. Cook until pasta is tender.',
  'Season well and scatter parsley before serving.',
]},

{id:37,name:'Minestrone Verde with Poached Fish',category:'Soups',difficulty:'medium',serves:2,time:'40 min',calories:380,mainIngredient:'Fish',
ingredients:[
  {name:'Olive oil',amount:60,unit:'ml'},
  {name:'Leek, sliced',amount:0.5,unit:'whole'},
  {name:'Fennel bulb, sliced (fronds kept)',amount:1,unit:'whole'},
  {name:'Garlic cloves, sliced',amount:3,unit:'cloves'},
  {name:'Zucchinis, sliced',amount:4,unit:'whole'},
  {name:'Vegetable or chicken stock',amount:2000,unit:'ml'},
  {name:'Cavolo nero, sliced',amount:1,unit:'handful'},
  {name:'Cannellini beans, rinsed',amount:400,unit:'g'},
  {name:'Asparagus or sugar snaps',amount:1,unit:'bunch'},
  {name:'White fish (ling, snapper), cubed',amount:300,unit:'g'},
  {name:'Peas',amount:140,unit:'g'},
  {name:'Salmoriglio',amount:80,unit:'ml'},
  {name:'Lemon zest and juice',amount:1,unit:'lemon'},
],
steps:[
  'Fry leek, fennel and garlic in oil with a pinch of salt for 8 minutes. Add zucchini, cook 5 minutes.',
  'Add stock and simmer 15 minutes. Stir in cavolo nero.',
  'Add cannellini beans, asparagus and fish. Cover and poach for 3 minutes.',
  'Crush peas and mix with salmoriglio, lemon zest and juice, salt and pepper.',
  'Ladle soup into bowls and spoon pea pesto over. Top with fennel fronds and chilli flakes.',
]},

{id:38,name:'Minestrone Verde (Vegetarian)',category:'Soups',difficulty:'medium',serves:2,time:'35 min',calories:290,mainIngredient:'Vegetables',
ingredients:[
  {name:'Olive oil',amount:60,unit:'ml'},
  {name:'Leek, sliced',amount:0.5,unit:'whole'},
  {name:'Fennel bulb, sliced',amount:1,unit:'whole'},
  {name:'Garlic cloves, sliced',amount:3,unit:'cloves'},
  {name:'Zucchinis, sliced',amount:4,unit:'whole'},
  {name:'Vegetable stock',amount:2000,unit:'ml'},
  {name:'Cavolo nero, sliced',amount:1,unit:'handful'},
  {name:'Cannellini beans, rinsed',amount:400,unit:'g'},
  {name:'Asparagus or sugar snaps',amount:1,unit:'bunch'},
  {name:'Peas',amount:140,unit:'g'},
  {name:'Lemon zest and juice',amount:1,unit:'lemon'},
  {name:'Salmoriglio (optional)',amount:80,unit:'ml'},
],
steps:[
  'Fry leek, fennel and garlic with salt in oil for 8 minutes. Add zucchini, cook 5 minutes.',
  'Add stock and simmer 15 minutes. Stir in cavolo nero.',
  'Add cannellini beans, peas and asparagus. Cook until just tender.',
  'Season with lemon zest, lemon juice, chilli flakes and olive oil or salmoriglio.',
]},

{id:39,name:'Prawn Laksa',category:'Soups',difficulty:'medium',serves:4,time:'30 min',calories:420,mainIngredient:'Prawns',
ingredients:[
  {name:'Vegetable oil',amount:30,unit:'ml'},
  {name:'Onion, chopped',amount:1,unit:'whole'},
  {name:'Garlic cloves, chopped',amount:2,unit:'cloves'},
  {name:'Fresh ginger, grated',amount:15,unit:'g'},
  {name:'Laksa paste',amount:30,unit:'g'},
  {name:'Chicken stock',amount:750,unit:'ml'},
  {name:'Coconut milk',amount:400,unit:'ml'},
  {name:'Rice noodles',amount:200,unit:'g'},
  {name:'Prawns, peeled',amount:300,unit:'g'},
  {name:'Bean sprouts, coriander and lime',amount:1,unit:'to serve'},
],
steps:[
  'Heat oil in a pot. Fry onion, garlic and ginger until soft, about 4 minutes.',
  'Stir in laksa paste and cook 1 minute until fragrant.',
  'Add stock and coconut milk. Simmer 10 minutes.',
  'Cook rice noodles separately and divide into bowls.',
  'Add prawns to soup and cook until pink, 2–3 minutes. Pour over noodles and serve with sprouts, coriander and lime.',
]},

{id:40,name:'Roast Pumpkin Soup with Coconut & Chilli',category:'Soups',difficulty:'easy',serves:4,time:'45 min',calories:260,mainIngredient:'Pumpkin',
ingredients:[
  {name:'Pumpkin, peeled and diced',amount:1000,unit:'g'},
  {name:'Olive oil',amount:30,unit:'ml'},
  {name:'Onion, chopped',amount:1,unit:'whole'},
  {name:'Garlic cloves, chopped',amount:2,unit:'cloves'},
  {name:'Red chilli, chopped',amount:1,unit:'whole'},
  {name:'Vegetable stock',amount:750,unit:'ml'},
  {name:'Coconut milk',amount:400,unit:'ml'},
  {name:'Lime juice',amount:30,unit:'ml'},
],
steps:[
  'Heat oven to 200°C. Toss pumpkin with olive oil, roast 25 minutes until tender.',
  'Sauté onion, garlic and chilli in a pot until soft.',
  'Add roasted pumpkin, stock and coconut milk. Simmer 10 minutes.',
  'Blend until smooth. Stir in lime juice and season to taste. Serve hot.',
]},

{id:41,name:'Seafood Chowder',category:'Soups',difficulty:'medium',serves:4,time:'45 min',calories:380,mainIngredient:'Seafood',
ingredients:[
  {name:'Butter',amount:30,unit:'g'},
  {name:'Onion, chopped',amount:1,unit:'whole'},
  {name:'Celery sticks, chopped',amount:2,unit:'stalks'},
  {name:'Carrots, diced',amount:2,unit:'whole'},
  {name:'Potatoes, diced',amount:2,unit:'whole'},
  {name:'Plain flour',amount:30,unit:'g'},
  {name:'Fish stock',amount:750,unit:'ml'},
  {name:'Milk',amount:300,unit:'ml'},
  {name:'White fish fillets, cubed',amount:200,unit:'g'},
  {name:'Prawns, peeled',amount:200,unit:'g'},
  {name:'Mussels, cleaned',amount:200,unit:'g'},
  {name:'Parsley, chopped',amount:1,unit:'handful'},
],
steps:[
  'Melt butter in a pot. Cook onion, celery and carrots until soft. Stir in flour.',
  'Gradually add stock and milk, stirring until smooth. Simmer 10 minutes.',
  'Add potatoes and cook until tender, about 10 minutes.',
  'Stir in fish, prawns and mussels. Cook until seafood is just done, about 5 minutes.',
  'Season and scatter parsley before serving.',
]},

{id:42,name:'Sicilian Fish Soup',category:'Soups',difficulty:'medium',serves:4,time:'50 min',calories:310,mainIngredient:'Fish',
ingredients:[
  {name:'Red onion',amount:1,unit:'whole'},
  {name:'Celery sticks',amount:2,unit:'stalks'},
  {name:'Fennel bulb',amount:0.5,unit:'small'},
  {name:'Garlic cloves',amount:2,unit:'cloves'},
  {name:'Red chilli, deseeded',amount:1,unit:'whole'},
  {name:'Olive oil',amount:30,unit:'ml'},
  {name:'Dry white wine',amount:150,unit:'ml'},
  {name:'Chopped plum tomatoes or passata',amount:800,unit:'g'},
  {name:'Butternut squash, grated',amount:0.5,unit:'whole'},
  {name:'Fish stock',amount:500,unit:'ml'},
  {name:'Salmon fillet, skinned',amount:200,unit:'g'},
  {name:'Halibut fillet, skinned',amount:300,unit:'g'},
  {name:'Raw peeled prawns',amount:12,unit:'whole'},
  {name:'Lemon juice',amount:15,unit:'ml'},
  {name:'Flat-leaf parsley, chopped',amount:1,unit:'handful'},
],
steps:[
  'Finely chop onion, celery, fennel, garlic and chilli. Heat oil in a large pan and sweat vegetables gently until soft.',
  'Add wine, tomatoes, grated squash and stock. Bring to the boil, cover and simmer 30 minutes. Season.',
  'Roughly chop salmon and halibut, add to the pan with prawns. Cover and simmer 10 minutes.',
  'Taste and season with salt, pepper and lemon juice.',
  'Serve drizzled with olive oil and scattered with parsley.',
]},

