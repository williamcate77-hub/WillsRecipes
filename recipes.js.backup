  {name:'Avocados, wedged',amount:2,unit:'whole'},
  {name:'Kalamata olives',amount:50,unit:'g'},
],
steps:[
  'If using canned chickpeas, simmer with a splash of their liquid for 3 minutes until creamy.',
  'Mix grated tomato, chickpeas, olive oil, lemon juice, garlic, half the pomegranate molasses and sumac.',
  'Pile into a bowl. Drizzle tahini and remaining molasses over the top. Sprinkle sumac.',
  'Top with herbs, cucumber, avocado wedges and olives. Drizzle with more oil.',
]},

{id:33,name:'Quinoa Tabbouleh with Pomegranate & Mint',category:'Salads',difficulty:'easy',serves:2,time:'20 min',calories:340,mainIngredient:'Quinoa',
